{
  "name": "agentic-ds",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "audit:ui": "node scripts/audit-ui.mjs",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "registry:build": "shadcn build",
    "test": "vitest run",
    "verify": "pnpm run lint && pnpm run typecheck && pnpm run format:check && node scripts/audit-ui.mjs --fail && node scripts/sync-registry.mjs --check && node scripts/check-registry-deps.mjs && pnpm run build && pnpm run registry:build"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@hugeicons/core-free-icons": "^4.0.0",
    "@hugeicons/react": "^1.1.6",
    "@tailwindcss/postcss": "4.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-resizable-panels": "4.11.2",
    "streamdown": "2.5.0",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@next/eslint-plugin-next": "^16.2.9",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "24.12.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "9.39.4",
    "eslint-plugin-react-hooks": "7.0.1",
    "globals": "^16.5.0",
    "jsdom": "^29.1.1",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "shadcn": "4.10.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.57.0",
    "vitest": "4.1.8"
  }
}
